@namespace(uri="library", prefix="")
package library;

class Library {
   val Writer[*] writers;
   val Book[*] books;
   val Publisher[*] publishers;
}

class Writer {
   attr String name;
   ref Book[*] books;
}

class Book {
   attr String title;
   attr int pages = 100;
   attr BookCategory category;
   ref Publisher publisher;
}

class Publisher {
   attr String name;
   attr String country;
}

enum BookCategory {
   History;
   Geography;
}